{
  "name": "vscode-notebook-mcp-server",
  "version": "0.1.0",
  "description": "MCP Server for VS Code Notebook",
  "type": "module",
  "bin": "./out/standaloneServer.js",
  "scripts": {
    "compile": "tsc -p ./",
    "start": "node ./out/standaloneServer.js",
    "package": "pkg . --targets node18-win-x64,node18-linux-x64,node18-darwin-x64 --output ./dist/standaloneServer"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "pkg": "^5.8.1"
  }
}
