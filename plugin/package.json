{
    "name": "vscode-notebook-mcp",
    "displayName": "VS Code Notebook MCP Server",
    "description": "MCP server for VS Code native notebooks",
    "version": "0.1.0",
    "publisher": "local-dev",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": ["Other"],
    "activationEvents": [
      "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
      "commands": [
        {
          "command": "notebookMcp.startServer",
          "title": "Start Notebook MCP Server"
        },
        {
          "command": "notebookMcp.stopServer",
          "title": "Stop Notebook MCP Server"
        }
      ]
    },
    "scripts": {
      "compile": "tsc -p ./",
      "watch": "tsc -watch -p ./",
      "package": "vsce package"
    },
    "dependencies": {
      "express": "^4.18.2",
      "@types/express": "^4.17.21"
    },
    "devDependencies": {
      "@types/vscode": "^1.80.0",
      "@types/node": "^20.0.0",
      "typescript": "^5.0.0",
      "@vscode/vsce": "^2.19.0"
    }
}
